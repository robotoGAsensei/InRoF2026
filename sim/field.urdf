  <!-- ジョイント -->

  <joint name="center_island_fixed_joint" type="fixed">
    <parent link="base_point"/>
    <child link="center_island"/>
    <origin xyz="0.9 0.9 0.02" rpy="0 0 0"/>
  </joint>

  <joint name="top_side_wall_fixed_joint" type="fixed">
    <parent link="base_point"/>
    <child link="top_side_wall"/>
    <origin xyz="0.9 1.805 0.02" rpy="0 0 0"/>
