<?xml version="1.0"?>
<robot name="large_cube">

  <!-- リンク -->

  <!-- スタート台 -->

  <!-- 基準点 -->
  <link name="base_point">
    <visual>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
                iyy="0.01" iyz="0"
                izz="0.01"/>
    </inertial>
  </link>

